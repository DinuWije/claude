# Load aliases
source "$HOME/.aliases"

# PATH helpers — idempotent so re-sourcing doesn't duplicate entries
path_prepend() { case ":$PATH:" in *":$1:"*) ;; *) PATH="$1:$PATH" ;; esac; }
path_append()  { case ":$PATH:" in *":$1:"*) ;; *) PATH="$PATH:$1" ;; esac; }

# Load homebrew shell variables
if [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Force certain more-secure behaviours from homebrew
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_CASK_OPTS=--require-sha
export HOMEBREW_DIR=/opt/homebrew
export HOMEBREW_BIN=/opt/homebrew/bin

# Load python shims
command -v pyenv &>/dev/null && eval "$(pyenv init -)"

# Load ruby shims
command -v rbenv &>/dev/null && eval "$(rbenv init -)"

# Prefer GNU binaries to Macintosh binaries.
path_prepend "/opt/homebrew/opt/coreutils/libexec/gnubin"

# Go
export GOPATH="$HOME/go"
path_prepend "$GOPATH/bin"
export GO111MODULE=auto
export GOPRIVATE=github.com/DataDog
export GOPROXY=binaries.ddbuild.io,https://proxy.golang.org,direct
export GONOSUMDB=github.com/DataDog,go.ddbuild.io

# AWS session config
export AWS_VAULT_KEYCHAIN_NAME=login
export AWS_SESSION_TTL=24h
export AWS_ASSUME_ROLE_TTL=1h

# Helm
export HELM_DRIVER=configmap

# pipx
path_append "$HOME/.local/bin"
export PATH

# Machine-specific overrides (not tracked in repo)
if [ -f ~/.zshrc.local ]; then
  source ~/.zshrc.local
fi
